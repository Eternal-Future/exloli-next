# 日志等级
log_level = "info,sqlx=warn,teloxide=error,exloli_next=debug"
# 下载线程的数量
# NOTE: 上传线程数量固定为 1
threads_num = 1
# 每次扫描的间隔
interval = "1h"
# 数据库文件位置
database_url = "db.sqlite"

[exhentai]
# 站点选择: "ehentai" 表站 或 "exhentai" 里站
site = "exhentai"
# 基础 cookie (ipb_member_id 和 ipb_pass_hash)
# 注意：这里只填写基础 cookie，不要包含 igneous
cookie = "ipb_member_id=xxxxx; ipb_pass_hash=xxxxx"
# igneous 值（可选，仅里站需要）
# 如果启用自动刷新，程序会自动维护这个值
igneous = "xxxxx"
# 是否自动刷新 igneous（仅里站有效）
auto_refresh_igneous = true
# 刷新 igneous 的 cron 表达式（默认每天 0 点）
# 格式: 秒 分 时 日 月 星期 年
refresh_cron = "0 0 0 * * * *"
# 搜索参数
search_params = [
    ["f_cats", "577"],
    ["f_search", "female:lolicon language:Chinese"]
]
# 搜索多少本本子（注意不是页数）
# 将此处设置为 0，就不会主动上传任何本子
search_count = 10
# 翻译文件的位置，每隔半小时自动更新
# 前往 https://github.com/EhTagTranslation/Database 下载
trans_file = "db.text.json"

[exhentai.proxy]
# 代理模式: "none" 不代理, "half" 半代理（仅刷新 igneous 时使用）, "full" 全代理
mode = "none"
# 代理地址（mode 为 half 或 full 时必填）
# 支持 http 和 socks5 协议
# 示例: "http://127.0.0.1:7890" 或 "socks5://127.0.0.1:1080"
url = "socks5://127.0.0.1:1080"

[telegraph]
# telegrah 账号 token
access_token = "xxxx"
# 发布文章时使用的作者名字
author_name = "exloli"
# 发布文章时使用的作者名称
author_url = "https://t.me/exlolicon"

[telegram]
# 频道 ID，如果是私有频道，这里可以填数字 ID
channel_id = "@xxx"
# 群组 ID，因为我懒，所以这里只能填数字 ID，如果填写的 ID 不存在，则不会发送投票
# 可以用 @myidbot 来获取你的频道和群组 ID
group_id = -1001423106182
# 如果频道使用了审核链接，bot 会自动批准该群组的成员加入
# 如果用不到这个功能，可以随便填
auth_group_id = -1001423106182
# bot ID
bot_id ="test_bot"
# bot token
token = "xxxx:xxxxxxxx"

[onebot]
# OneBot 推送为可选项；false 时不会启动反向 WebSocket 服务
enabled = false
# OneBot/NapCat 作为 WebSocket 客户端连接：ws://<host>:<port>/expush
# 公网传输场景可监听 0.0.0.0；启用时必须设置 access_token
listen_host = "0.0.0.0"
# 0 表示首次启动时在 30000-60000 随机选择未占用端口并写回配置文件
listen_port = 0
# 固定为 /expush，不支持其它路径
path = "/expush"
# OneBot 连接鉴权：Authorization: Bearer <token> 或 ?access_token=<token>
access_token = "change-me"
# 私聊白名单。为空时不会进行 QQ 私聊推送，也不会响应私聊 #ping/#latestbook
private_user_ids = []
# 群聊白名单。为空时不会进行 QQ 群推送，也不会响应群聊 #ping/#latestbook
group_ids = []
# Telegraph 代理预览域名。为空时不展示“代理预览”行；启用前请确保该域名已反代 Telegraph
telegraph_proxy_host = ""

[s3]
# s3 地区
region = "region"
# s3 api 地址
endpoint = "https://endpoint.s3.com"
# 桶名称
bucket = "name"
# access key
access_key = "ak"
# secret key
secret_key = "sk"
# 桶绑定的域名
host = "example.com"
